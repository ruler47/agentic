# Agentic local development environment.
# Copy this file to .env and adjust model/provider values:
#   cp .env.example .env

# API/UI
PORT=3000
WEB_REACT_PORT=3001
AGENT_TIME_ZONE=Europe/Madrid
TZ=Europe/Madrid

# Durable local stores from docker-compose infra services.
DATABASE_URL=postgres://agentic:agentic@127.0.0.1:5432/agentic
MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_ACCESS_KEY=agentic
MINIO_SECRET_KEY=agentic-password
MINIO_BUCKET=agentic-artifacts
ARTIFACT_ROOT=workspace/artifacts
FILE_TOOL_ROOT=workspace

# Search/browser/channel tool endpoints for host development.
SEARXNG_BASE_URL=http://127.0.0.1:8080
BROWSER_OPERATE_BASE_URL=http://127.0.0.1:18080
CHANNEL_TELEGRAM_BASE_URL=http://127.0.0.1:18081
TELEGRAM_BOT_BASE_URL=http://127.0.0.1:18081

# Local OpenAI-compatible LLM, usually LM Studio.
LLM_BASE_URL=http://127.0.0.1:1234/v1
LLM_MODEL=google/gemma-4-26b-a4b
LLM_TEMPERATURE=0.2
LLM_REQUEST_TIMEOUT_MS=60000

# Optional tier overrides. Comma-separated fallbacks are supported.
# LLM_MODEL_TIER_S=google/gemma-4-26b-a4b
# LLM_MODEL_TIER_M=google/gemma-4-26b-a4b,qwen/qwen3.6-35b-a3b
# LLM_MODEL_TIER_L=qwen/qwen3.6-35b-a3b
# LLM_MODEL_TIER_XL=qwen/qwen3.6-35b-a3b

# Optional operator-verified model capability overrides.
# Keep this provider-neutral; runtime routing filters by tier first, then capability.
LLM_MODEL_CAPABILITIES=qwen/qwen3.6-35b-a3b=vision,reasoning,tool-calling;google/gemma-4-26b-a4b=vision

# Optional API auth. Leave unset for local React UI development until the UI stores/sends it.
# AGENTIC_API_TOKEN=

# Core toolbelt is enabled by default. Use disabled only for focused tests.
# BUILTIN_TOOLS=disabled
