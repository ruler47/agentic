{
  "name": "agentic-universal-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/cli.ts",
    "docker": "npm run infra:start",
    "docker:stop": "npm run infra:stop",
    "docker:full": "docker compose up --build",
    "docker:full:detached": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "infra:start": "docker compose up -d postgres redis minio searxng",
    "infra:stop": "docker compose stop postgres redis minio searxng",
    "infra:restart": "npm run infra:stop && npm run infra:start",
    "infra:logs": "docker compose logs -f postgres redis minio searxng",
    "web": "node scripts/web-react-dev.mjs",
    "web:dev": "node scripts/web-react-dev.mjs",
    "web:api": "node dist/server/main.nest.js",
    "web:api:dev": "tsx src/server/main.nest.ts",
    "serve": "node dist/db/migrate.js && node dist/server/main.nest.js",
    "test": "tsx --test --test-concurrency=1 tests/*.test.ts tests/**/*.test.ts",
    "test:types": "tsc --noEmit -p tsconfig.test.json",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" \"web-react/src/**/*.{ts,tsx}\"",
    "verify": "npm run lint && npm run typecheck && npm run test:types && npm test && npm run build",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "start": "node dist/cli.js"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/express": "^5.0.6",
    "@types/node": "^20.12.12",
    "@types/pg": "^8.20.0",
    "@types/pngjs": "^6.0.5",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "pngjs": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.59.3"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/serve-static": "^5.0.5",
    "@nestjs/swagger": "^11.4.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^3.25.76"
  }
}
