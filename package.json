{
  "name": "agentic-universal-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/cli.ts",
    "web": "node dist/server/main.js",
    "web:dev": "tsx src/server/main.ts",
    "serve": "node dist/db/migrate.js && node dist/server/main.js",
    "test": "tsx --test tests/*.test.ts tests/**/*.test.ts",
    "test:types": "tsc --noEmit -p tsconfig.test.json",
    "verify": "npm run typecheck && npm run test:types && npm test && npm run build",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "start": "node dist/cli.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.12.12",
    "@types/pg": "^8.20.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "pg": "^8.20.0"
  }
}
